rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if the user is the master admin override
    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token != null && 
             request.auth.token.email != null && 
             request.auth.token.email == 'abdulsamadtaiwo648@gmail.com';
    }

    // Helper to check if user has a document in /admins
    function hasAdminDoc() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin override helper - Allow only the master admin
    function isAdmin() {
      return isMasterAdmin();
    }

    // Server-side write bypass check
    function isServerBypass(data) {
      return data != null && 
             data.systemSecret == 'dlnz_secure_bypass_2026_qwert';
    }

    // Catch-all Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for Admins segment
    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() || (request.resource != null && isServerBypass(request.resource.data));
    }

    // Rules for Products segment
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || 
                   (request.resource != null && isServerBypass(request.resource.data)) ||
                   (resource != null && isServerBypass(resource.data));
    }

    // Rules for Orders segment
    match /orders/{orderId} {
      allow read: if true;
      allow create: if isSignedIn() || 
                    (request.resource != null && isServerBypass(request.resource.data));
      allow update: if isAdmin() || 
                    (request.resource != null && isServerBypass(request.resource.data)) ||
                    (resource != null && isServerBypass(resource.data));
      allow delete: if isAdmin() || 
                    (resource != null && isServerBypass(resource.data));
    }

    // Rules for Support Chats segment
    match /support_chats/{chatSessionId} {
      allow read: if true;
      allow write: if request.resource.data.id == chatSessionId || isAdmin();
    }
  }
}
