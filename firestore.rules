rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if the user is the master admin override
    function isMasterAdmin() {
      return isSignedIn() && 
             request.auth.token != null && 
             request.auth.token.email != null && 
             request.auth.token.email == 'abdulsamadtaiwo648@gmail.com';
    }

    // Helper to check if user has a document in /admins
    function hasAdminDoc() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admin override helper - Allow any signed-in user to act as admin
    function isAdmin() {
      return isSignedIn();
    }

    // Catch-all Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for Admins segment
    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Rules for Products segment
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Rules for Orders segment
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        (resource != null && 'userId' in resource.data && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      allow create: if isSignedIn() && 
                    request.resource != null && 
                    'userId' in request.resource.data && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
