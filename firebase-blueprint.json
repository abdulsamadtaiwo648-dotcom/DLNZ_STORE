{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An e-commerce product in the DLNZ collection.",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "featured": { "type": "boolean" },
        "limited": { "type": "boolean" },
        "material": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "details": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "name", "price", "category", "image", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Processing", "Shipped", "Hold", "Delivered"] },
        "tracking": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "amount", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with management privileges.",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Public product listings."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/admins/{userId}": {
      "schema": "Admin",
      "description": "List of authorized administrators."
    }
  }
}
